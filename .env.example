# Copy this file to .env and fill in your values.

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Any chat model hosted by Groq
MODEL_NAME=llama-3.3-70b-versatile

# Credentials the generated Selenium tests will use to log in
# to the application under test (optional — login tests are
# skipped if not set)
TEST_USERNAME=
TEST_PASSWORD=
